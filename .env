# Daily Challan Notify Job Schedule
# DAILY_CHALLAN_NOTIFY_CRON=22 6 * * *
DAILY_CHALLAN_NOTIFY_CRON=0 7 * * *
DAILY_CHALLAN_NOTIFY_TZ=Asia/Kolkata
CHALLAN_LOOKBACK_DAYS=2 

# Stakeholder notification recipients (comma-separated)
