# ── PayU payment gateway (challan settlement) ────────────────────────────────
# Sandbox / test defaults below are PayU's public test merchant credentials, so
# the module works out-of-the-box against https://test.payu.in. Replace KEY/SALT
# and switch PAYU_BASE_URL to https://secure.payu.in/_payment for production.
PAYU_MERCHANT_KEY=gtKFFx
PAYU_MERCHANT_SALT=4R38IvwiV57FwVpsgOvTXBdLE4tHUXFW
PAYU_BASE_URL=https://test.payu.in/_payment
# Server endpoints PayU redirects the browser back to (must stay public / no JWT).
# In production set these to the live server, e.g. https://server.smartchallan.com/settlement/payu/callback/success
PAYU_SURL=http://localhost:3001/settlement/payu/callback/success
PAYU_FURL=http://localhost:3001/settlement/payu/callback/failure
# Fallback SPA origin to send the user back to after payment (used when the
# request did not carry a recognised return_origin).
APP_REDIRECT_BASE=http://localhost:5173
