# Vehicle EChallan Batch Job Schedule
ECHALLAN_JOB_CRON=0 */6 * * *
ECHALLAN_JOB_TZ=Asia/Kolkata

# Vehicle RTO Batch Job Schedule
RTO_JOB_CRON=0 9 * * *
RTO_JOB_TZ=Asia/Kolkata

# ULIP API Rate Limiting & Batch Settings
# Max ULIP API calls per second across ALL services (RTO + Challan, batch + on-demand)
ULIP_RATE_LIMIT_PER_SECOND=8
# Max concurrent vehicle calls within a single batch (per client)
ULIP_BATCH_CONCURRENCY=4
# Delay in ms between batches within a single client's job run
ULIP_BATCH_DELAY_MS=1000
# Pause in ms between processing different clients in the daily batch job
ULIP_CLIENT_PAUSE_MS=2000
